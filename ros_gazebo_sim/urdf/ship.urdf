<?xml version="1.0"?>
<robot name="autonomous_ship" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 材料属性 -->
  <material name="ship_hull">
    <color rgba="0.2 0.3 0.5 1.0"/>
  </material>
  <material name="ship_deck">
    <color rgba="0.6 0.65 0.7 1.0"/>
  </material>
  <material name="propeller">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="sensor">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <!-- ===== base_link: 船体主体 ===== -->
  <link name="base_link">
    <inertial>
      <mass value="500.0"/>
      <origin xyz="0 0 -0.3" rpy="0 0 0"/>
      <inertia ixx="800.0" ixy="0.0" ixz="0.0"
               iyy="2000.0" iyz="0.0"
               izz="2000.0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ship_navigation_sim/models/ship_hull.dae" scale="1 1 1"/>
      </geometry>
      <material name="ship_hull"/>
    </visual>

    <!-- 简化碰撞体: 箱体近似船体 -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="8.0 2.0 2.5"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== base_footprint: 地面投影 ===== -->
  <link name="base_footprint">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 -0.5" rpy="0 0 0"/>
  </joint>

  <!-- ===== 左推进器 ===== -->
  <link name="left_thruster">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.2" length="0.3"/>
      </geometry>
      <material name="propeller"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.2" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_thruster_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_thruster"/>
    <origin xyz="-3.5 -0.6 -0.5" rpy="0 1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="50"/>
  </joint>

  <!-- ===== 右推进器 ===== -->
  <link name="right_thruster">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.2" length="0.3"/>
      </geometry>
      <material name="propeller"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.2" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_thruster_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_thruster"/>
    <origin xyz="-3.5 0.6 -0.5" rpy="0 1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="50"/>
  </joint>

  <!-- ===== 二维激光雷达 ===== -->
  <link name="laser_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.15"/>
      </geometry>
      <material name="sensor"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="4.0 0 0.5" rpy="0 0 0"/>
  </joint>

  <!-- ===== IMU ===== -->
  <link name="imu_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===== Gazebo差分驱动插件 ===== -->
  <gazebo>
    <plugin name="ship_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <rosDebugLevel>na</rosDebugLevel>
      <publishWheelTF>true</publishWheelTF>
      <publishWheelJointState>true</publishWheelJointState>
      <alwaysOn>true</alwaysOn>
      <updateRate>100.0</updateRate>
      <leftJoint>left_thruster_joint</leftJoint>
      <rightJoint>right_thruster_joint</rightJoint>
      <wheelSeparation>1.2</wheelSeparation>
      <wheelDiameter>0.4</wheelDiameter>
      <maxWheelTorque>200</maxWheelTorque>
      <maxWheelAcceleration>10.0</maxWheelAcceleration>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <publishOdomTF>true</publishOdomTF>
      <odometrySource>world</odometrySource>
      <publishWheelJointState>true</publishWheelJointState>
      <wheelTorque>20</wheelTorque>
      <commandTopic>cmd_vel</commandTopic>
    </plugin>
  </gazebo>

  <!-- ===== 激光雷达传感器 ===== -->
  <gazebo reference="laser_link">
    <sensor name="laser" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-1.57</min_angle>
            <max_angle>1.57</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="laser_plugin" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>laser_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== IMU传感器 ===== -->
  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu.so">
        <topicName>imu/data</topicName>
        <frameName>imu_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>