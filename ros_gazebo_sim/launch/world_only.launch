<?xml version="1.0"?>
<launch>
  <!-- 只启动Gazebo场景 (不含导航) -->

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find ship_navigation_sim)/worlds/restricted_waterway.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <param name="robot_description"
         command="$(find xacro)/xacro '$(find ship_navigation_sim)/urdf/ship.urdf'"/>

  <node name="spawn_ship" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model autonomous_ship -param robot_description
              -x 0 -y 0 -z 0.5 -Y 0"
        output="screen"/>

  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"/>
  <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher"/>

</launch>