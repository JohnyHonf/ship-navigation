<?xml version="1.0"?>
<launch>
  <!-- 完整仿真启动: 场景 + 船舶 + 传感器 + 导航 + 控制 -->

  <!-- 1. 启动Gazebo并加载场景 -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find ship_navigation_sim)/worlds/restricted_waterway.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- 2. 加载船舶URDF模型 -->
  <param name="robot_description"
         command="$(find xacro)/xacro '$(find ship_navigation_sim)/urdf/ship.urdf'"/>

  <node name="spawn_ship" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model autonomous_ship -param robot_description
              -x 0 -y 0 -z 0.5 -Y 0"
        output="screen"/>

  <!-- 3. 机器人状态发布 -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"/>

  <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher">
    <param name="publish_frequency" value="50"/>
  </node>

  <!-- 4. EKF定位 -->
  <node name="ekf_localization" pkg="robot_localization" type="ekf_localization_node">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/ekf_localization.yaml"/>
  </node>

  <!-- 5. 全局路径规划器 -->
  <node name="global_planner" pkg="ship_navigation_sim" type="global_planner_node.py"
        output="screen">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/global_planner_params.yaml"/>
  </node>

  <!-- 6. DWA局部规划器 -->
  <node name="dwa_planner" pkg="ship_navigation_sim" type="dwa_planner_node.py"
        output="screen">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/dwa_params.yaml"/>
  </node>

  <!-- 7. 纯追踪控制器 -->
  <node name="pure_pursuit" pkg="ship_navigation_sim" type="pure_pursuit_node.py"
        output="screen">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/pure_pursuit_params.yaml"/>
  </node>

  <!-- 8. 指标采集器 -->
  <node name="metrics_collector" pkg="ship_navigation_sim" type="metrics_collector.py"
        output="screen"/>

  <!-- 9. Rviz可视化 -->
  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find ship_navigation_sim)/config/ship_navigation.rviz"
        unless="$(arg headless)"/>

</launch>