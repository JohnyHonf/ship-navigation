<?xml version="1.0"?>
<launch>
  <!-- 导航系统启动 (需要先启动world_only.launch) -->

  <node name="ekf_localization" pkg="robot_localization" type="ekf_localization_node">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/ekf_localization.yaml"/>
  </node>

  <node name="global_planner" pkg="ship_navigation_sim" type="global_planner_node.py"
        output="screen">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/global_planner_params.yaml"/>
  </node>

  <node name="dwa_planner" pkg="ship_navigation_sim" type="dwa_planner_node.py"
        output="screen">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/dwa_params.yaml"/>
  </node>

  <node name="pure_pursuit" pkg="ship_navigation_sim" type="pure_pursuit_node.py"
        output="screen">
    <rosparam command="load" file="$(find ship_navigation_sim)/config/pure_pursuit_params.yaml"/>
  </node>

  <node name="metrics_collector" pkg="ship_navigation_sim" type="metrics_collector.py"
        output="screen"/>

  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find ship_navigation_sim)/config/ship_navigation.rviz"/>

</launch>