<?xml version="1.0"?>
<launch>
  <!-- 实验4: 变宽度航道 -->

  <include file="$(find ship_navigation_sim)/launch/full_simulation.launch"/>

  <node name="experiment_runner" pkg="ship_navigation_sim" type="experiment_runner.py"
        output="screen">
    <param name="experiment_type" value="narrow"/>
    <param name="goal_x" value="40.0"/>
    <param name="goal_y" value="0.0"/>
    <param name="timeout" value="600"/>
  </node>
</launch>